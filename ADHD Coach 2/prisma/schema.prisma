generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TEEN
  THERAPIST
  PARENT
  ADMIN
}

enum Visibility {
  PRIVATE
  THERAPIST_SHARED
  PARENT_SHARED
}

enum ConnectionStatus {
  PENDING
  ACTIVE
  REVOKED
}

enum ConsentStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  ARCHIVED
}

enum TaskStatus {
  TODO
  DONE
  SKIPPED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(TEEN)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  teenProfile      TeenProfile?
  therapistProfile TherapistProfile?
  parentProfile    ParentProfile?
  accounts         Account[]
  sessions         Session[]
  goalsCreated     Goal[]       @relation("GoalCreator")
  routinesCreated  Routine[]    @relation("RoutineCreator")
  auditLogs        AuditLog[]
  invitationsSent  Invitation[] @relation("InvitationSender")
  sentMessages     Message[]    @relation("MessageSender")
  receivedMessages Message[]    @relation("MessageRecipient")
}

model TeenProfile {
  id                    String        @id @default(cuid())
  userId                String        @unique
  dateOfBirth           DateTime?
  consentStatus         ConsentStatus @default(PENDING)
  parentAccessEnabled   Boolean       @default(false)
  emergencyContactName  String?
  emergencyContactPhone String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user                  User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  therapistConnections  TherapistTeenConnection[]
  parentConnections     TeenParentConnection[]
  checkIns              CheckIn[]
  goals                 Goal[]
  routines              Routine[]
  tasks                 Task[]
  reflections           Reflection[]
  therapistNotes        TherapistNote[]
  messages              Message[]
  invitations           Invitation[]
}

model TherapistProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  licenseInfo  String?
  organization String?
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  connections  TherapistTeenConnection[]
  notes        TherapistNote[]
}

model ParentProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  connections TeenParentConnection[]
}

model TherapistTeenConnection {
  id          String           @id @default(cuid())
  therapistId String
  teenId      String
  status      ConnectionStatus @default(PENDING)
  createdAt   DateTime         @default(now())

  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  teen      TeenProfile      @relation(fields: [teenId], references: [id], onDelete: Cascade)

  @@unique([therapistId, teenId])
}

model TeenParentConnection {
  id                  String           @id @default(cuid())
  teenId              String
  parentId            String
  accessLevel         Visibility        @default(PARENT_SHARED)
  approvedByTeen      Boolean           @default(false)
  approvedByTherapist Boolean           @default(false)
  status              ConnectionStatus  @default(PENDING)
  createdAt           DateTime          @default(now())

  teen   TeenProfile   @relation(fields: [teenId], references: [id], onDelete: Cascade)
  parent ParentProfile @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([teenId, parentId])
}

model CheckIn {
  id          String   @id @default(cuid())
  teenId      String
  moodScore   Int
  energyScore Int
  focusScore  Int
  stressScore Int
  sleepHours  Float?
  notes       String?
  createdAt   DateTime @default(now())

  teen TeenProfile @relation(fields: [teenId], references: [id], onDelete: Cascade)

  @@index([teenId, createdAt])
}

model Goal {
  id          String     @id @default(cuid())
  teenId      String
  createdById String
  title       String
  description String?
  status      GoalStatus @default(ACTIVE)
  visibility  Visibility @default(THERAPIST_SHARED)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  teen      TeenProfile @relation(fields: [teenId], references: [id], onDelete: Cascade)
  createdBy User        @relation("GoalCreator", fields: [createdById], references: [id])
  tasks     Task[]

  @@index([teenId, status])
  @@index([createdById])
}

model Routine {
  id          String     @id @default(cuid())
  teenId      String
  createdById String
  title       String
  description String?
  frequency   String
  timeOfDay   String?
  status      GoalStatus @default(ACTIVE)
  visibility  Visibility @default(THERAPIST_SHARED)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  teen      TeenProfile @relation(fields: [teenId], references: [id], onDelete: Cascade)
  createdBy User        @relation("RoutineCreator", fields: [createdById], references: [id])
  tasks     Task[]

  @@index([teenId, status])
  @@index([createdById])
}

model Task {
  id          String     @id @default(cuid())
  teenId      String
  routineId   String?
  goalId      String?
  title       String
  status      TaskStatus @default(TODO)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  completedAt DateTime?

  teen    TeenProfile @relation(fields: [teenId], references: [id], onDelete: Cascade)
  routine Routine?    @relation(fields: [routineId], references: [id], onDelete: SetNull)
  goal    Goal?       @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([teenId, status])
  @@index([routineId])
  @@index([goalId])
}

model Reflection {
  id         String     @id @default(cuid())
  teenId     String
  prompt     String
  content    String
  visibility Visibility @default(PRIVATE)
  createdAt  DateTime   @default(now())

  teen TeenProfile @relation(fields: [teenId], references: [id], onDelete: Cascade)

  @@index([teenId, createdAt])
}

model TherapistNote {
  id          String   @id @default(cuid())
  therapistId String
  teenId      String
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  teen      TeenProfile      @relation(fields: [teenId], references: [id], onDelete: Cascade)

  @@index([therapistId, teenId])
}

model Invitation {
  id          String    @id @default(cuid())
  email       String
  role        Role
  invitedById String
  teenId      String?
  tokenHash   String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  invitedBy User @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)
  teen      TeenProfile? @relation(fields: [teenId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([invitedById])
  @@index([teenId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId, createdAt])
  @@index([targetType, targetId])
}

model Message {
  id          String    @id @default(cuid())
  teenId      String
  senderId    String
  recipientId String
  body        String
  createdAt   DateTime  @default(now())
  readAt      DateTime?

  teen      TeenProfile @relation(fields: [teenId], references: [id], onDelete: Cascade)
  sender    User        @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User        @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([teenId, createdAt])
  @@index([senderId])
  @@index([recipientId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}
